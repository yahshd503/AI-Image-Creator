{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Image Creator",
  "version": "1.0.0",
  "identifier": "com.aventatech.aiimagecreator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Image Creator",
        "width": 1380,
        "height": 860,
        "minWidth": 1380,
        "minHeight": 860,
        "maxWidth": 1380,
        "maxHeight": 860,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}